###############################################
# Backend environment example for Render
# Copy these into Render's dashboard (do NOT commit secrets)
###############################################

# MongoDB Atlas connection string (production)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# Local fallback (only used for local development if MONGO_URI is absent)
LOCAL_MONGO_URI=mongodb://127.0.0.1:27017/prishtinarepaircenterdb

# JWT / auth
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# Server port (Render provides this automatically; you can override for local testing)
PORT=5000

# Environment
NODE_ENV=production

# Allowed CORS origins (comma-separated). Default in code includes localhost dev and your production domains.
ALLOWED_ORIGINS=https://prishtinarepaircenter.com,https://www.prishtinarepaircenter.com,http://localhost:5173,http://localhost:3000

# Trust proxy — set to 1 when running behind a proxy (Render recommended)
TRUST_PROXY=1

# Cookie options (optional)
# If you want cookies to be shared across subdomains, set COOKIE_DOMAIN to .yourdomain.com
COOKIE_DOMAIN=.prishtinarepaircenter.com
